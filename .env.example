# OpenAI — used by the LLM parser
OPENAI_API_KEY=sk-...

# Twilio credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=+447XXXXXXXXX

# Fallback business details (used when no per-business values are set in the DB)
BUSINESS_NAME=Dave's Plumbing
BUSINESS_PAYMENT_DETAILS=Bank transfer: Sort 12-34-56, Acc 12345678 (D Smith)

# Public URL of this server (Railway app URL — used for Twilio signature validation)
# Must match the webhook URL configured in your Twilio console exactly
PUBLIC_URL=https://the-foreman-production.up.railway.app

# Sign-up URL shown to unregistered senders
SIGNUP_URL=https://www.the-foreman.com/signup

# Admin API secret (protect /admin/* endpoints)
ADMIN_SECRET=change-me-to-something-secure

# Optional
PORT=3000
